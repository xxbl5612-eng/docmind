# ── Application ──
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-256-bit-hex-string
API_V1_PREFIX=/api/v1

# ── PostgreSQL ──
DATABASE_URL=postgresql+asyncpg://docmind:docmind@localhost:5432/docmind
DATABASE_URL_SYNC=postgresql://docmind:docmind@localhost:5432/docmind

# ── Redis ──
REDIS_CACHE_URL=redis://localhost:6379/0
REDIS_BROKER_URL=redis://localhost:6379/1
REDIS_RESULT_BACKEND=redis://localhost:6379/2

# ── DeepSeek API ──
DEEPSEEK_API_KEY=sk-8b2d7d55976241c38749a51700aedb27
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
DEEPSEEK_RATE_LIMIT_RPM=60
DEEPSEEK_RATE_LIMIT_BURST=10
DEEPSEEK_REQUEST_TIMEOUT=120.0
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_CIRCUIT_BREAKER_THRESHOLD=10
DEEPSEEK_CIRCUIT_BREAKER_WINDOW=60
DEEPSEEK_CIRCUIT_BREAKER_RECOVERY=30
DEEPSEEK_DAILY_TOKEN_BUDGET=10000000

# ── MinIO / S3 ──
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=docmind
STORAGE_SECURE=false

# ── Celery ──
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=900

# ── JWT ──
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# ── GitHub OAuth ──
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:5173/auth/github/callback
GITHUB_OAUTH_TOKEN_ENCRYPTION_KEY=

# ── Document Processing ──
DOC_MAX_SYNC_CHARS=20000
DOC_CHUNK_SIZE=6000
DOC_CHUNK_OVERLAP=300
DOC_MAX_UPLOAD_SIZE_MB=500
